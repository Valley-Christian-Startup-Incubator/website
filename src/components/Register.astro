---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const orgUrl = 'https://github.com/Valley-Christian-Startup-Incubator';
const tapUrl = 'https://github.com/Valley-Christian-Startup-Incubator/tap';

// "What it is" — the conceptual facts, before any mechanical steps.
const facts = [
  {
    title: 'You keep your code',
    body: 'Your project lives in your own GitHub account. Registering just <strong>lists</strong> it — nothing moves into the org.',
  },
  {
    title: 'Bring hand-off docs',
    body: 'Your repo needs a <code>README</code> on how to <strong>maintain</strong>, <strong>deploy</strong>, and <strong>learn</strong> it.',
  },
  {
    title: "It's one pull request",
    body: 'Add a line to a shared file and open a PR. A mentor reviews it — your first real open-source contribution.',
  },
];

// The how-to: 3 steps, each paired 1:1 with the screenshot that shows it.
const steps = [
  {
    n: 1,
    title: 'Fork & edit the registry',
    body: `Fork the <a href="${tapUrl}" target="_blank" rel="noopener"><code>tap</code></a> repo, then add an entry to <code>registry.json</code> that points at your repo and links your docs.`,
    shot: `${base}/demo-edit.webp`,
    label: 'registry.json · GitHub',
    alt: 'GitHub web editor showing registry.json with a new project entry added to the array.',
  },
  {
    n: 2,
    title: 'Check your change',
    body: 'Open a compare view. You should see a clean green block adding your entry, and a green <strong>“Able to merge”</strong> check.',
    shot: `${base}/demo-diff.webp`,
    label: 'Comparing changes',
    alt: 'GitHub compare view showing 11 additions, a green diff block, and an "Able to merge" check.',
  },
  {
    n: 3,
    title: 'Open the pull request',
    body: 'Give it a title and hit <strong>Create pull request</strong>. A mentor reviews it, and once merged, you\'re registered. 🎉',
    shot: `${base}/demo-pr.webp`,
    label: 'Open a pull request',
    alt: 'GitHub open-a-pull-request form with a title, description, and the green Create pull request button.',
  },
];

---

<section id="register" class="relative scroll-mt-20 px-5 py-24 sm:px-8 md:py-32">
  <!-- The one section drenched in saffron, to announce it as the main event -->
  <div
    class="mx-auto max-w-6xl overflow-hidden rounded-[28px] border-[1.5px] border-ink bg-saffron shadow-hard-lg"
  >
    <div class="px-5 py-12 sm:px-12 sm:py-16">
      <div class="max-w-2xl">
        <span
          class="reveal inline-flex items-center rounded-full border-[1.5px] border-ink bg-surface px-3 py-1 text-xs font-bold text-ink"
          >Start here</span
        >
        <h2
          class="reveal mt-5 text-[clamp(2rem,5.5vw,3.6rem)] text-ink"
          data-reveal-delay="0.05"
        >
          Register your business or project
        </h2>
        <p
          class="reveal mt-5 max-w-prose text-lg text-ink/80"
          data-reveal-delay="0.1"
        >
          Here's exactly what it is and exactly what you do.
        </p>
      </div>

      <!-- WHAT IT IS — the concepts, before any mechanics -->
      <div class="reveal mt-10 grid gap-4 sm:grid-cols-3" data-reveal-delay="0.08">
        {
          facts.map((f) => (
            <div class="rounded-2xl border-[1.5px] border-ink bg-surface p-5">
              <h3 class="font-display text-lg font-bold text-ink">{f.title}</h3>
              <p
                class="mt-1.5 text-[0.95rem] leading-relaxed text-ink-muted [&_code]:rounded [&_code]:bg-ink [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:font-mono [&_code]:text-[0.82em] [&_code]:text-banana [&_strong]:font-semibold [&_strong]:text-ink"
                set:html={f.body}
              />
            </div>
          ))
        }
      </div>

      <!-- DO IT — 3 steps, each paired 1:1 with its screenshot -->
      <h3
        class="reveal mt-14 font-display text-2xl font-extrabold text-ink sm:text-3xl"
        data-reveal-delay="0.05"
      >
        Do it in 3 steps
      </h3>

      <ol class="mt-6 space-y-6">
        {
          steps.map((s) => (
            <li
              class="reveal grid items-center gap-5 rounded-2xl border-[1.5px] border-ink bg-surface p-5 shadow-hard sm:p-6 lg:grid-cols-[0.85fr_1.15fr] lg:gap-8"
              data-reveal-delay="0.06"
            >
              {/* instruction */}
              <div class="flex gap-4">
                <span class="grid h-10 w-10 flex-none place-items-center rounded-full border-[1.5px] border-ink bg-saffron font-display text-lg font-extrabold text-ink">
                  {s.n}
                </span>
                <div class="min-w-0">
                  <h4 class="text-xl font-bold leading-snug text-ink">{s.title}</h4>
                  <p
                    class="mt-1.5 leading-relaxed text-ink-muted [overflow-wrap:anywhere] [&_a]:underline [&_a]:decoration-2 [&_a]:underline-offset-2 [&_a]:transition-opacity [&_a:hover]:opacity-80 [&_code]:rounded [&_code]:bg-ink [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:font-mono [&_code]:text-[0.82em] [&_code]:text-banana [&_code]:[overflow-wrap:anywhere] [&_strong]:font-semibold [&_strong]:text-ink"
                    set:html={s.body}
                  />
                </div>
              </div>

              {/* the screenshot that shows exactly this step */}
              <figure class="min-w-0 overflow-hidden rounded-xl border-[1.5px] border-ink bg-surface">
                <figcaption class="flex items-center gap-2 border-b-[1.5px] border-ink bg-bg px-3 py-2">
                  <span class="flex gap-1.5" aria-hidden="true">
                    <span class="h-2.5 w-2.5 rounded-full border border-ink/30 bg-[#ff5f57]" />
                    <span class="h-2.5 w-2.5 rounded-full border border-ink/30 bg-[#febc2e]" />
                    <span class="h-2.5 w-2.5 rounded-full border border-ink/30 bg-[#28c840]" />
                  </span>
                  <span class="ml-1 truncate font-mono text-xs text-ink-muted">
                    {s.label}
                  </span>
                </figcaption>
                <img
                  src={s.shot}
                  alt={s.alt}
                  width="1400"
                  loading="lazy"
                  decoding="async"
                  class="block w-full"
                />
              </figure>
            </li>
          ))
        }
      </ol>

      <!-- CTA row -->
      <div
        class="reveal mt-12 flex flex-col items-start gap-4 sm:flex-row sm:items-center"
        data-reveal-delay="0.1"
      >
        <a
          href={tapUrl}
          target="_blank"
          rel="noopener"
          class="group inline-flex items-center gap-2 rounded-full border-[1.5px] border-ink bg-ink px-7 py-3.5 text-base font-bold text-bg shadow-hard transition-transform hover:-translate-y-0.5"
        >
          Open the registry repo
          <span class="transition-transform group-hover:translate-x-0.5">↗</span>
        </a>
        <a
          href={orgUrl}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-full border-[1.5px] border-ink bg-surface px-7 py-3.5 text-base font-bold text-ink transition-transform hover:-translate-y-0.5"
        >
          Browse the organization
        </a>
        <p class="text-sm font-medium text-ink/70 sm:ml-2">
          New to pull requests? A mentor will walk you through it.
        </p>
      </div>

      <!-- The org-transfer exception, called out clearly -->
      <div
        class="reveal mt-10 flex items-start gap-3 rounded-2xl border-[1.5px] border-ink bg-surface p-5"
        data-reveal-delay="0.05"
      >
        <span
          class="mt-0.5 grid h-6 w-6 flex-none place-items-center rounded-full border-[1.5px] border-ink bg-sky text-sm font-extrabold text-ink"
          aria-hidden="true">!</span
        >
        <p class="text-[0.95rem] leading-relaxed text-ink-muted">
          <strong class="font-bold text-ink">When do you move the repo into the
            org?</strong> Only when you're leaving and have no apprentices to take
          over. Transferring into
          <code
            class="rounded bg-ink px-1.5 py-0.5 font-mono text-[0.82em] text-banana [overflow-wrap:anywhere]"
            >Valley-Christian-Startup-Incubator</code
          > hands the project to the next generation. Otherwise, keep owning it.
        </p>
      </div>
    </div>
  </div>
</section>
